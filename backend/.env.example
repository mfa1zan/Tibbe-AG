NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
KG_CACHE_TTL_SECONDS=600
KG_CACHE_MAXSIZE=512
# ===== Model for Intent Understanding / Query Parsing =====
MODEL_INTENT=llama-3.1-8b-instant

# ===== Model for Neo4j / KG Query Generation =====
MODEL_KG=compound

# ===== Model for Draft Answer / Reasoning =====
MODEL_REASONER=llama-3.3-70b-versatile

# ===== Model for Validation / Safety / Mechanistic Check =====
MODEL_VALIDATOR=gpt-oss-20b

# ===== Model for Chat with User =====
MODEL_CHAT=llama-3.3-70b-versatile

# ===== Optional: Audio Transcription =====
MODEL_AUDIO=whisper-large-v3-turbo

# ===== API Keys =====
GROQ_API_KEY=your_api_key_here