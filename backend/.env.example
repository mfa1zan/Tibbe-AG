# ===== Neo4j Database =====
NEO4J_URI=neo4j+s://<your-db>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ===== Groq API =====
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ===== Model for Intent / Entity Extraction =====
MODEL_INTENT=llama-3.1-8b-instant

# ===== Model for Chat / Answer Generation =====
MODEL_CHAT=llama-3.3-70b-versatile

# ===== Judge Service =====
ENABLE_JUDGE=true

# ===== Logging =====
LOG_LEVEL=INFO

# make it false if you don't want detailed backend logs
DEBUG_TRACE=true